    "Change your Patch now. Insulin delivery will stop in {0} or when no more insulin remains." : {
      "comment" : "description for grace period notice",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتغيير اللصقة الآن. سيتوقف توصيل الأنسولين خلال %@ أو عندما لا يتبقى المزيد من الأنسولين."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Změňte svou záplatu. Podávání inzulínu se zastaví za %@ nebo až nezbude žádný další inzulín."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skift dit plaster nu. Insulintilførslen stopper om %@, eller når der ikke er mere insulin tilbage."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pflaster jetzt austauschen. Die Insulinabgabe stoppt in %@ oder wenn kein Insulin mehr vorhanden ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Change your Patch now. Insulin delivery will stop in %@ or when no more insulin remains."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambie su parche ahora. La administración de insulina se detendrá en %@ o cuando no quede más insulina."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaihda Patch nyt. Insuliinin jakelu loppuu %@:n kuluttua tai kun insuliinia ei ole enää jäljellä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remplacez le patch maintenant. La distribution d'insuline s'arrête dans %@ ou lorsqu'il n'y a plus d'insuline."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שנה את התיקון שלך עכשיו. אספקת האינסולין תיפסק ב %@ או כאשר לא יישאר עוד אינסולין."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Változtassa meg a Patchet most. Az inzulinadagolás %@ vagy akkor áll le, amikor már nem marad inzulin."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambiare subito il cerotto. La somministrazione di insulina si interromperà tra %@ o quando non ci sarà più insulina."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今すぐパッチを交換してください。インスリンの投与は、%@ またはインスリンの残りがなくなると停止します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "지금 패치를 변경하세요. 인슐린 전달이 %@에서 중단되거나 더 이상 인슐린이 남아 있지 않을 때 중단됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bytt plaster nå. Insulintilførselen vil stoppe om %@ eller når det ikke er mer insulin igjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vervang Patch nu. De insulinetoediening stopt over %@ of wanneer er geen insuline meer is."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zmień teraz plaster. Podawanie insuliny zakończy się za %@ lub gdy insulina przestanie działać."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mude o seu Patch agora. A administração de insulina será interrompida em %@ ou quando não houver mais insulina."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schimbați plasturele acum. Administrarea insulinei se va opri în %@ sau când nu va mai rămâne insulină."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Смените пластырь немедленно. Выдача инсулина прекратится через %@ или когда инсулина больше не останется."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zmeňte svoju záplatu. Podávanie inzulínu sa zastaví za %@ alebo keď už nezostane žiadny inzulín."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zdaj spremenite svoj paket. Dostavljanje insulina se bo ustavilo v %@ ali ko ne bo več insulina."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ändra din patch nu. Insulintillförseln kommer att upphöra om %@ eller när det inte finns mer insulin kvar."
          }
