    "Are you sure you want to stop using Medtrum TouchCare Nano 200u/300u?" : {
      "comment" : "Message for PumpManager deletion action sheet",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد من أنك تريد التوقف عن استخدام Medtrum TouchCare Nano 200u/300u؟"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to stop using Medtrum TouchCare Nano 200u/300u?"
          }
