          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Şırıngayı banda yerleştirin ve 1 ila 2 çizgi hava çekin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
