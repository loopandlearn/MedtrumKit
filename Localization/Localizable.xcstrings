          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stellen Sie sicher, dass die Seriennummer korrekt ist, bevor Sie sie mit dem Patch verbinden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Make sure the Serial Number is correct before connecting it to the patch."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asegúrese de que el número de serie es correcto antes de conectarlo al parche."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varmista, että sarjanumero on oikein ennen kuin yhdistät sen laastariin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
