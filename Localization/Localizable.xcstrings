振動とビープ音"}},"nb-NO":{"stringUnit":{"state":"translated","value":"Vibrerer og piper"}},"pl":{"stringUnit":{"state":"translated","value":"Wibracje i dźwięk"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Vibrar e bipe"}},"ro":{"stringUnit":{"state":"translated","value":"Vibrare și bip"}},"sk":{"stringUnit":{"state":"translated","value":"Vibrácie a zvukový signál"}},"sl":{"stringUnit":{"state":"translated","value":"Vibriranje in piskanje"}},"es":{"stringUnit":{"state":"translated","value":"Vibrar y beep"}},"sv":{"stringUnit":{"state":"translated","value":"Vibrera och pipa"}},"tr":{"stringUnit":{"state":"translated","value":"Titreşim ve bip sesi"}},"uk":{"stringUnit":{"state":"translated","value":"Вібрація та звуковий сигнал"}},"vi":{"stringUnit":{"state":"translated","value":"Vibrate and beep"}},"nb":{"stringUnit":{"state":"translated","value":"Vibrer og pipende"}}}},"Vibrate-only":{"extractionState":"manual","comment":"Label for alarm options: vibrate","localizations":{"en":{"stringUnit":{"state":"translated","value":"Vibrate-only"}},"nb":{"stringUnit":{"state":"translated","value":"Kun Vibrasjon"}},"vi":{"stringUnit":{"state":"translated","value":"Vibrate-only"}},"uk":{"stringUnit":{"state":"translated","value":"Тільки вібрація"}},"tr":{"stringUnit":{"state":"translated","value":"Yalnızca titreşim"}},"sv":{"stringUnit":{"state":"translated","value":"Endast vibrerande"}},"es":{"stringUnit":{"state":"translated","value":"Solo vibración"}},"sl":{"stringUnit":{"state":"translated","value":"Samo vibriranje"}},"sk":{"stringUnit":{"state":"translated","value":"Iba vibrovať"}},"ru":{"stringUnit":{"state":"translated","value":"Только вибрация"}},"ro":{"stringUnit":{"state":"translated","value":"Numai Vibrați-de-mare"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Somente vibração"}},"pl":{"stringUnit":{"state":"translated","value":"Tylko wibracje"}},"nb-NO":{"stringUnit":{"state":"translated","value":"Kun vibrasjon"}},"ja":{"stringUnit":{"state":"translated","value":"振動のみ"}},"it":{"stringUnit":{"state":"translated","value":"Solo Vibrazione"}},"de":{"stringUnit":{"state":"translated","value":"Nur Vibration"}},"fr":{"stringUnit":{"state":"translated","value":"Vibrer uniquement"}},"fi":{"stringUnit":{"state":"translated","value":"Vain Värinä"}},"nl":{"stringUnit":{"state":"translated","value":"Enkel trillingen"}},"da":{"stringUnit":{"state":"translated","value":"Kun vibrationQShortcut"}},"cs":{"stringUnit":{"state":"translated","value":"Vibrate-only"}},"ar":{"stringUnit":{"state":"translated","value":"فيبرايت فقط"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"仅振动"}}}},"Welcome":{"extractionState":"manual","comment":"welcome header","localizations":{"nb":{"stringUnit":{"state":"translated","value":"Velkommen"}},"en":{"stringUnit":{"state":"translated","value":"Welcome"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"欢迎使用"}},"ar":{"stringUnit":{"state":"translated","value":"مرحبا بك"}},"cs":{"stringUnit":{"state":"translated","value":"Welcome"}},"da":{"stringUnit":{"state":"translated","value":"Velkommen"}},"nl":{"stringUnit":{"state":"translated","value":"Verwelkoming"}},"fi":{"stringUnit":{"state":"translated","value":"Tervetuloa"}},"fr":{"stringUnit":{"state":"translated","value":"Bienvenue"}},"de":{"stringUnit":{"state":"translated","value":"Begrüßung"}},"it":{"stringUnit":{"state":"translated","value":"Benvenuto"}},"ja":{"stringUnit":{"state":"translated","value":"ようこそ"}},"nb-NO":{"stringUnit":{"state":"translated","value":"Velkommen"}},"pl":{"stringUnit":{"state":"translated","value":"Witaj"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Boas-vindas"}},"ro":{"stringUnit":{"state":"translated","value":"Bun venit"}},"ru":{"stringUnit":{"state":"translated","value":"Добро пожаловать"}},"sk":{"stringUnit":{"state":"translated","value":"Vitajte"}},"sl":{"stringUnit":{"state":"translated","value":"Dobrodošli"}},"es":{"stringUnit":{"state":"translated","value":"Bienvenida"}},"sv":{"stringUnit":{"state":"translated","value":"Välkommen"}},"tr":{"stringUnit":{"state":"translated","value":"Hoş geldiniz"}},"uk":{"stringUnit":{"state":"translated","value":"Ласкаво просимо."}},"vi":{"stringUnit":{"state":"translated","value":"Welcome"}}}},"When clicking on the button, you will get a Biometrics prompt. Once completed, the patch will be deactivated and you will be prompted to pair a new patch.":{"extractionState":"manual","comment":"Instructions for deactivate patch","localizations":{"pl":{"stringUnit":{"state":"translated","value":"Po kliknięciu przycisku otrzymasz komunikat biometryczny. Po zakończeniu plaster zostanie zdezaktywowany i zostanie poproszony o parę nowego plastra."}},"nb":{"stringUnit":{"state":"translated","value":"Når du klikker på knappen, vil du få en biometrisk ledetekst. Når depotplasteret er ferdig, vil det bli deaktivert og du vil bli bedt om å pare et nytt depotplaster"}},"vi":{"stringUnit":{"state":"translated","value":"When clicking on the button, you will get a Biometrics prompt. Once completed, the patch will be deactivated and you will be prompted to pair a new patch."}},"uk":{"stringUnit":{"state":"translated","value":"Після натискання на кнопку з'явиться запит на проходження біометрії. Після цього патч буде деактивовано, і вам буде запропоновано підключити новий патч."}},"tr":{"stringUnit":{"state":"translated","value":"Düğmeye tıkladığınızda bir Biyometri istemi alacaksınız. Tamamlandığında, yama devre dışı bırakılacak ve yeni bir yama eşleştirmeniz istenecektir."}},"sv":{"stringUnit":{"state":"translated","value":"När du klickar på knappen får du en Biometrics prompt. När den är klar, kommer patchen att inaktiveras och du kommer att uppmanas att para ihop en ny patch."}},"es":{"stringUnit":{"state":"translated","value":"Al hacer clic en el botón, obtendrá un indicador biométrico. Una vez completado, el parche será desactivado y se le pedirá que empareje un nuevo parche."}},"sl":{"stringUnit":{"state":"translated","value":"Ko kliknete na gumb, se prikaže poziv za vnos biometričnih podatkov. Po zaključku se bo obliž deaktiviral in pozvan bo k seznanitvi z novim obližem."}},"sk":{"stringUnit":{"state":"translated","value":"Po kliknutí na tlačidlo sa zobrazí výzva na biometrickú identifikáciu. Po jej dokončení sa náplasť deaktivuje a zobrazí sa výzva na spárovanie novej náplasti."}},"ru":{"stringUnit":{"state":"translated","value":"Нажав на кнопку, вы получите запрос на биометрию. После завершения, патч будет деактивирован и вам будет предложено парять новый патч."}},"ro":{"stringUnit":{"state":"translated","value":"Când faceți clic pe buton, veți primi o solicitare biometrică. Odată finalizat, plasturele va fi dezactivat şi vi se va solicita să asociaţi un nou plasture transdermic."}},"pt-BR":{"stringUnit":{"state":"translated","value":"Ao clicar no botão, você receberá um prompt de Biometria. Uma vez concluído, o patch será desativado e você será solicitado para parear um novo patch."}},"nb-NO":{"stringUnit":{"state":"translated","value":"Når du klikker på knappen, får du en biometrisk melding. Når du er ferdig, deaktiveres lappen, og du blir bedt om å koble til en ny lapp."}},"ja":{"stringUnit":{"state":"translated","value":"ボタンをクリックすると、バイオメトリクスのプロンプトが表示されます。完了すると、パッチは無効化され、新しいパッチをペアリングするよう促されます。"}},"it":{"stringUnit":{"state":"translated","value":"Quando si fa clic sul pulsante, si otterrà un prompt Biometrica. Una volta completato, il cerotto sarà disattivato e le verrà chiesto di abbinare un nuovo cerotto."}},"de":{"stringUnit":{"state":"translated","value":"Wenn Sie auf den Button klicken, erhalten Sie eine biometrische Eingabeaufforderung. Sobald der Patch abgeschlossen ist, wird der Patch deaktiviert und Sie werden aufgefordert, einen neuen Patch zu koppeln."}},"fr":{"stringUnit":{"state":"translated","value":"En cliquant sur le bouton, vous obtiendrez une invite biométrique. Une fois terminé, le patch sera désactivé et vous serez invité à associer un nouveau patch."}},"fi":{"stringUnit":{"state":"translated","value":"Kun napsautat painiketta, saat Biometricsin kehotuksen. Kun laastari on valmis, se poistetaan käytöstä ja sinua kehotetaan yhdistämään uusi laastar."}},"nl":{"stringUnit":{"state":"translated","value":"Wanneer je op de knop klikt, krijg je een Biometrie prompt. Zodra klaar is wordt de patch gedeactiveerd en wordt je gevraagd om een nieuwe patch te koppelen."}},"da":{"stringUnit":{"state":"translated","value":"Når du klikker på knappen, vil du få en Biometrics prompt. Når plasteret er færdigt, vil det blive deaktiveret, og De vil blive bedt om at parre et nyt plaster."}},"cs":{"stringUnit":{"state":"translated","value":"When clicking on the button, you will get a Biometrics prompt. Once completed, the patch will be deactivated and you will be prompted to pair a new patch."}},"ar":{"stringUnit":{"state":"translated","value":"عند النقر على الزر، ستحصل على طلب من القياسات الحيوية. بمجرد اكتمال التصحيح سوف يتم تعطيله وسيتم مطالبتك باقران تعديل جديد."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"点击按钮时，您将获得生物计提示。 完成后，补丁将被停用，您将被提示配对一个新补丁。"}},"en":{"stringUnit":{"state":"translated","value":"When clicking on the button, you will get a Biometrics prompt. Once completed, the patch will be deactivated and you will be prompted to pair a new patch."}}}},"Yes, Disable heartbeat mode":{"extractionState":"manual","comment":"Button text to disable heartbeat mode","localizations":{"nb":{"stringUnit":{"state":"translated","value":"Ja, deaktiver hjerteslagmodus"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"是，禁用心跳动模式"}},"ar":{"stringUnit":{"state":"translated","value":"نعم، قم بتعطيل وضع حبات القلب"}},"cs":{"stringUnit":{"state":"translated","value":"Yes, Disable heartbeat mode"}},"da":{"stringUnit":{"state":"translated","value":"Ja, Deaktivér hjertebank-tilstand"}},"nl":{"stringUnit":{"state":"translated","value":"Ja, Schakel hartbeet modus uit"}},"fi":{"stringUnit":{"state":"translated","value":"Kyllä, Poista syke tila käytöstä"}},"fr":{"stringUnit":{"state":"translated","value":"Oui, désactiver le mode de pulsation"}},"de":{"stringUnit":{"state":"translated","value":"Ja, Herzbeat-Modus deaktivieren"}},"it":{"stringUnit":{"state":"translated","value":"Sì, Disabilita la modalità battito cardiaco"}},"ja":{"stringUnit":{"state":"translated","value":"はい、ハートビートモードを無効にする"}},"nb-NO":{"stringUnit":{"state":"translated","value":"Ja, Deaktiver hjerterytmemodus"}},"en":{"stringUnit":{"state":"translated","value":"Yes, Disable heartbeat mode"}},"pl":{"stringUnit":{"state":"translated","value":"Tak, wyłącz tryb bicia serca"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Sim, desativar o modo pulso"}},"ro":{"stringUnit":{"state":"translated","value":"Da, dezactivează modul bătăi ale inimii"}},"ru":{"stringUnit":{"state":"translated","value":"Да, отключить режим heartbeat"}},"sk":{"stringUnit":{"state":"translated","value":"Áno, vypnúť režim heartbeat"}},"sl":{"stringUnit":{"state":"translated","value":"Da, onemogočite način srčnega utripa"}},"es":{"stringUnit":{"state":"translated","value":"Sí, deshabilitar modo latido cardiaco"}},"sv":{"stringUnit":{"state":"translated","value":"Ja, inaktivera hjärtslag läge"}},"tr":{"stringUnit":{"state":"translated","value":"Evet, Kalp atışı modunu devre dışı bırak"}},"uk":{"stringUnit":{"state":"translated","value":"Так, Вимкнути режим серцебиття"}},"vi":{"stringUnit":{"state":"translated","value":"Yes, Disable heartbeat mode"}}}},"Yes, Enable heartbeat mode":{"extractionState":"manual","comment":"Button text to enable heartbeat mode","localizations":{"en":{"stringUnit":{"state":"translated","value":"Yes, Enable heartbeat mode"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"是，启用心跳模式"}},"ar":{"stringUnit":{"state":"translated","value":"نعم، تمكين وضع نبضات القلب"}},"cs":{"stringUnit":{"state":"translated","value":"Yes, Enable heartbeat mode"}},"da":{"stringUnit":{"state":"translated","value":"Ja, Aktiver hjerteslag tilstand"}},"nl":{"stringUnit":{"state":"translated","value":"Ja, hartslag modus inschakelen"}},"fi":{"stringUnit":{"state":"translated","value":"Kyllä, Ota syke käyttöön"}},"fr":{"stringUnit":{"state":"translated","value":"Oui, activer le mode pulsation"}},"de":{"stringUnit":{"state":"translated","value":"Ja, Herzbeat-Modus aktivieren"}},"it":{"stringUnit":{"state":"translated","value":"Sì, Abilita la modalità battito cardiaco"}},"ja":{"stringUnit":{"state":"translated","value":"はい、ハートビートモードを有効にする"}},"nb-NO":{"stringUnit":{"state":"translated","value":"Ja, Aktiver hjerteslagmodus"}},"pl":{"stringUnit":{"state":"translated","value":"Tak, Włącz tryb bicia serca"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Sim, Ativar modo pulso"}},"ro":{"stringUnit":{"state":"translated","value":"Da, activează modul bătăi ale inimii"}},"ru":{"stringUnit":{"state":"translated","value":"Да, включить режим heartbeat"}},"sk":{"stringUnit":{"state":"translated","value":"Áno, zapnúť režim heartbeat"}},"sl":{"stringUnit":{"state":"translated","value":"Da, Omogočite način srčnega utripa"}},"es":{"stringUnit":{"state":"translated","value":"Sí, activar el modo latido cardiaco"}},"sv":{"stringUnit":{"state":"translated","value":"Ja, Aktivera hjärtslagsläge"}},"tr":{"stringUnit":{"state":"translated","value":"Evet, Kalp atışı modunu etkinleştir"}},"uk":{"stringUnit":{"state":"translated","value":"Так, Увімкнути режим серцебиття"}},"vi":{"stringUnit":{"state":"translated","value":"Yes, Enable heartbeat mode"}},"nb":{"stringUnit":{"state":"translated","value":"Ja, Aktiver hjerteslag-modus"}}}},"Yes, Sync to Current Time":{"extractionState":"manual","comment":"Button text to confirm pump time sync","localizations":{"en":{"stringUnit":{"state":"translated","value":"Yes, Sync to Current Time"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"是，与当前时间同步"}},"ar":{"stringUnit":{"state":"translated","value":"نعم، المزامنة مع الوقت الحالي"}},"cs":{"stringUnit":{"state":"translated","value":"Ano, synchronizovat na aktuální čas"}},"da":{"stringUnit":{"state":"translated","value":"Ja, synkroniser til aktuel tid"}},"nl":{"stringUnit":{"state":"translated","value":"Ja, synchroniseren met huidige tijd"}},"fi":{"stringUnit":{"state":"translated","value":"Kyllä, synkronointi nykyiseen aikaan"}},"fr":{"stringUnit":{"state":"translated","value":"Oui, synchronisation avec l'heure actuelle"}},"de":{"stringUnit":{"state":"translated","value":"Ja, Synchronisierung mit der aktuellen Zeit"}},"it":{"stringUnit":{"state":"translated","value":"Sì, sincronizzazione con l'ora corrente"}},"ja":{"stringUnit":{"state":"translated","value":"はい、現在時刻に同期"}},"nb-NO":{"stringUnit":{"state":"translated","value":"Ja, synkroniser til gjeldende tid"}},"pl":{"stringUnit":{"state":"translated","value":"Tak, synchronizacja z bieżącym czasem"}},"pt-BR":{"stringUnit":{"state":"translated","value":"Sim, sincronização com a hora atual"}},"ro":{"stringUnit":{"state":"translated","value":"Da, sincronizați cu ora curentă"}},"ru":{"stringUnit":{"state":"translated","value":"Да, синхронизация с текущим временем"}},"sk":{"stringUnit":{"state":"translated","value":"Áno, synchronizácia s aktuálnym časom"}},"sl":{"stringUnit":{"state":"translated","value":"Da, sinhronizacija s trenutnim časom"}},"es":{"stringUnit":{"state":"translated","value":"Sí, sincronización con la hora actual"}},"sv":{"stringUnit":{"state":"translated","value":"Ja, synkroniseras med aktuell tid"}},"tr":{"stringUnit":{"state":"translated","value":"Evet, Geçerli Saatle Senkronize Et"}},"nb":{"stringUnit":{"state":"translated","value":"Ja, synkroniser til gjeldende tid"}},"uk":{"stringUnit":{"state":"translated","value":"Так, Синхронізувати з поточним часом"}},"vi":{"stringUnit":{"state":"translated","value":"Vâng, Đồng bộ hóa với thời gian hiện tại"}}}},"You will start by setting up your insulin type & basic patch settings before activating your patch.":{"extractionState":"manual","comment":"Welcome text for MedtrumKit","localizations":{"ar":{"stringUnit":{"state":"translated","value":"ستبدأ بإعداد نوع الأنسولين وإعدادات التصحيح الأساسية قبل تفعيل التصحيح الخاص بك."}},"nb":{"stringUnit":{"state":"translated","value":"Du starter med å sette opp insulin type & grunnleggende plasterinnstillinger før du aktiverer depotplasteret."}},"vi":{"stringUnit":{"state":"translated","value":"You will start by setting up your insulin type & basic patch settings before activating your patch."}},"uk":{"stringUnit":{"state":"translated","value":"Перед активацією пластиру ви почнете з визначення типу інсуліну та основних налаштувань пластиру."}},"tr":{"stringUnit":{"state":"translated","value":"Yamanızı etkinleştirmeden önce insülin tipinizi ve temel yama ayarlarınızı yaparak başlayacaksınız."}},"sv":{"stringUnit":{"state":"translated","value":"Du kommer att börja med att konfigurera din insulintyp och grundläggande patchinställningar innan du aktiverar din patch."}},"es":{"stringUnit":{"state":"translated","value":"Empezará por configurar su tipo de insulina y la configuración básica del parche antes de activar el parche."}},"sl":{"stringUnit":{"state":"translated","value":"Preden boste aktivirali svoj obliž, boste najprej nastavili svojo vrsto insulina in osnovne nastavitve obliža."}},"sk":{"stringUnit":{"state":"translated","value":"Pred aktiváciou náplasti najskôr nastavíte typ inzulínu a základné nastavenia náplasti."}},"ru":{"stringUnit":{"state":"translated","value":"Перед активацией патча вы начнете с установки типа инсулин и базовых настроек патча."}},"ro":{"stringUnit":{"state":"translated","value":"Veţi începe prin a seta setările pentru tipul de insulină & plasturele de bază înainte de a activa plasturele."}},"pt-BR":{"stringUnit":{"state":"translated","value":"Você começará configurando as configurações do patch e do tipo insulina antes de ativar o patch."}},"pl":{"stringUnit":{"state":"translated","value":"Przed aktywacją plastra rozpocznie się konfiguracja typu insuliny i podstawowych ustawień plastra."}},"nb-NO":{"stringUnit":{"state":"translated","value":"Du starter med å konfigurere insulintype og grunnleggende plasterinnstillinger før du aktiverer plasteret."}},"ja":{"stringUnit":{"state":"translated","value":"パッチを有効にする前に、まずインスリンの種類と基本的なパッチの設定を行います。"}},"it":{"stringUnit":{"state":"translated","value":"Inizierà impostando il tipo di insulina e le impostazioni base del cerotto prima di attivare il cerotto."}},"de":{"stringUnit":{"state":"translated","value":"Du beginnst damit, deine Insulintypen und Grundpatcheinstellungen einzurichten, bevor du den Patch aktivierst."}},"fr":{"stringUnit":{"state":"translated","value":"Vous commencerez par configurer votre type d'insuline et vos paramètres de correctifs de base avant d'activer votre patch."}},"fi":{"stringUnit":{"state":"translated","value":"Aloitat asettamalla insuliinityypin ja laastarin perusasetukset ennen kuin otat laastarin käyttöön."}},"nl":{"stringUnit":{"state":"translated","value":"Je zal beginnen met het instellen van jouw insulinetype & basispatch instellingen voordat je jouw patch activeert."}},"da":{"stringUnit":{"state":"translated","value":"Du vil starte med at indstille dine indstillinger for insulintype og basisplaster, før du aktiverer dit plaster."}},"cs":{"stringUnit":{"state":"translated","value":"You will start by setting up your insulin type & basic patch settings before activating your patch."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"在激活补丁之前，您将先设置您的绝缘类型和基本补丁设置。"}},"en":{"stringUnit":{"state":"translated","value":"You will start by setting up your insulin type & basic patch settings before activating your patch."}}}},"Your patch has %i hours left":{"extractionState":"manual","comment":"Body expire reminder notification","localizations":{"nb":{"stringUnit":{"state":"translated","value":"Your patch has %%i hours left"}},"en":{"stringUnit":{"state":"translated","value":"Your patch has %%i hours left"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"您的补丁还剩 %%i 小时"}},"ar":{"stringUnit":{"state":"tran