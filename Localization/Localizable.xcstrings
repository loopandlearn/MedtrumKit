        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tryk på nåleknappen for at stikke nålen ind. Klik på \"Aktiver\" for at fuldføre aktiveringsprocessen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drücken Sie die Nadel Taste, um die Nadel einzulegen. Klicken Sie auf \"Aktivieren\", um den Aktivierungsvorgang abzuschließen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press the needle button to insert the needle. Click on \"Activate\" to complete the activation process."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pulse el botón de aguja para insertar la aguja. Haga clic en \"Activar\" para completar el proceso de activación."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paina neulan nappia lisätäksesi neulaa. Napsauta \"Aktivoi\" saadaksesi aktivointiprosessin valmiiksi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez sur le bouton de l'aiguille pour insérer l'aiguille. Cliquez sur \"Activer\" pour terminer le processus d'activation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premere il pulsante dell’ago per inserire l’ago. Fare clic su \"Attiva\" per completare il processo di attivazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "針ボタンを押して針を挿入します。Activate \"をクリックし、アクティベーションを完了します。"
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trykk på nåleknappen for å sette inn nålen. Klikk på \"Activate\" for å fullføre aktiveringsprosessen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Druk op de naaldknop om de naald in te voegen. Klik op \"Activeren\" om het activeringsproces te voltooien."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wcisnąć przycisk igły, aby wprowadzić igłę. Kliknij przycisk \"Aktywuj\", aby zakończyć proces aktywacji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pressione o botão da agulha para inserir a agulha. Clique em \"Ativar\" para concluir o processo de ativação."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apăsaţi butonul acului pentru a introduce acul. Faceţi clic pe \"Activare\" pentru a finaliza procesul de activare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нажмите на кнопку иглы, чтобы вставить иглу. Нажмите на кнопку \"Активировать\", чтобы завершить процесс активации."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stlačte tlačidlo ihly, aby ste vložili ihlu. Kliknite na „Aktivovať“, aby ste dokončili proces aktivácie."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pritisnite gumb za iglo, da vstavite iglo. Za dokončanje postopka aktivacije kliknite \"Activate\" (Aktiviraj)."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tryck på nålknappen för att sätta in nålen. Klicka på \"Aktivera\" för att slutföra aktiveringsprocessen."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İğneyi yerleştirmek için iğne düğmesine basın. Etkinleştirme işlemini tamamlamak için \"Etkinleştir\" üzerine tıklayın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Натисніть кнопку голки, щоб вставити голку. Натисніть \"Активувати\", щоб завершити процес активації."
          }
        },
        "vi" : {
