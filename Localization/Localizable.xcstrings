    "Press the needle button to insert the needle. Click on \"Activate\" to complete the activation process." : {
      "comment" : "Label for inserting needle step 3",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط على زر الإبرة لإدراج الإبرة. انقر على \"تفعيل\" لإكمال عملية التفعيل."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press the needle button to insert the needle. Click on \"Activate\" to complete the activation process."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tryk på nåleknappen for at stikke nålen ind. Klik på \"Aktiver\" for at fuldføre aktiveringsprocessen."
