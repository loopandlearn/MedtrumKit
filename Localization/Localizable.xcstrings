    "Place the syringe in the patch and pull out 1 to 2 dashes of air." : {
      "comment" : "Label for prime step 2.3",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ضع المحاقنة في التصحيح وسحب 1 إلى 2 شرطة من الهواء."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placer sprøjten i plasteret og træk 1 til 2 bindestreger luft ud."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legen Sie die Spritze in den Patch und ziehen Sie 1 bis 2 Bindestriche Luft aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Place the syringe in the patch and pull out 1 to 2 dashes of air."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coloque la jeringa en el parche y saque de 1 a 2 guiones de aire."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laita ruisku laastariin ja vedä ulos 1 - 2 ilman välipalaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Placez la seringue dans le patch et tirez 1 à 2 tirets d'air."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Place the syringe in the patch and pull out 1 to 2 dashes of air."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Posizionare la siringa nel cerotto e tirare fuori da 1 a 2 trattini d’aria."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plasser sprøyten i plasteret og trekk ut 1 til 2 streker med luft."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plaats de spuit in de patch en trek 1 tot 2 streepjes lucht."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Umieścić strzykawkę w plastrze i odciągnąć od 1 do 2 myślników powietrza."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coloque a seringa na atualização e extraia 1 a 2 traços de ar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
